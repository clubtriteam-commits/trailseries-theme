# WordPress — ignore core, configuration, uploads and logs.
# Repo root == WordPress root. Only our own theme + plugins are versioned.
# Based on https://github.com/github/gitignore/blob/main/WordPress.gitignore

# Core
/wp-admin/
/wp-includes/
/wp-content/index.php
/wp-content/languages
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php

# Configuration
wp-config.php

# Uploads
/wp-content/uploads/

# Log files
*.log

# htaccess (managed on the server; legacy rewrites documented in docs/)
/.htaccess

# All plugins EXCEPT ours
/wp-content/plugins/*
!/wp-content/plugins/trailseries-results/

# All themes EXCEPT ours
/wp-content/themes/*
!/wp-content/themes/trailseries/

# Dependencies / build artifacts
node_modules/
vendor/
*.zip
*.sql
*.sql.gz

# Migration working data (raw exports may contain personal data — never commit)
/migration/data/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
*.swp
